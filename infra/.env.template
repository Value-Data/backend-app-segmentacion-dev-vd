# =============================================================
# Garces Fruit - Sistema Segmentacion de Nuevas Especies
# Environment variables template
# Copy this file to backend/.env and fill in the values
# =============================================================

# ---- Database (SQL Server Azure) ----
DB_SERVER=tcp:your-server.database.windows.net,1433
DB_NAME=your-database
DB_USER=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 17 for SQL Server

# ---- JWT Authentication ----
JWT_SECRET_KEY=generate-a-strong-secret-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- App ----
APP_NAME=Sistema Segmentacion Especies
APP_VERSION=4.0.0
COMPANY_NAME=Garces Fruit
CURRENT_SEASON=2024-2025
DEBUG=false

# ---- Frontend (build-time only) ----
VITE_API_BASE_URL=/api/v1
